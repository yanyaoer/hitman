#!/usr/bin/env bash
# hitman control script. Manages the user MITM service, the root netd service,
# CA trust, status checks, and smoke tests. It does not edit SFM/sing-box config.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LABEL="com.hitman.srv"
NET_LABEL="com.hitman.net"
PORT=8471
DNS_PORT=8472
PLIST_SRC="$DIR/$LABEL.plist"
NET_PLIST_SRC="$DIR/$NET_LABEL.plist"
PLIST_DST="$HOME/Library/LaunchAgents/$LABEL.plist"
NET_PLIST_DST="/Library/LaunchDaemons/$NET_LABEL.plist"
CONFIG_PATH="${HITMAN_CONFIG:-$HOME/.config/hitman/config.json}"
LOG_ERR="$DIR/logs/hitman.err.log"
LOG_OUT="$DIR/logs/hitman.out.log"
NET_LOG_ERR="$DIR/logs/hitman-net.err.log"
NET_LOG_OUT="$DIR/logs/hitman-net.out.log"
GUI="gui/$(id -u)"
PB=/usr/libexec/PlistBuddy
RESOLVER_MARKER="# hitman managed resolver"

DEFAULT_HITMAN_DOMAINS="chatgpt.com,api.anthropic.com,generativelanguage.googleapis.com,aiplatform.googleapis.com"
DEFAULT_HITMAN_DOMAIN_SUFFIXES="aiplatform.googleapis.com"
DEFAULT_HITMAN_PROCESSES="codex,claude,claude.exe,gemini,omp,pi,agy"
DEFAULT_HITMAN_RESOLVER_DOMAINS="chatgpt.com,anthropic.com,googleapis.com"
DEFAULT_UPSTREAM_MODE="system"
DEFAULT_UPSTREAM_PROXY=""
DEFAULT_SOCKS_UPSTREAM="127.0.0.1:2333"
DEFAULT_HTTP_UPSTREAM="127.0.0.1:2334"
DEFAULT_DNS_UPSTREAM="1.1.1.1:53"

die() { echo "hitman: $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing required tool: $1"; }

plist_set_string() {
  local p="$1" key="$2" val="$3"
  "$PB" -c "Set $key $val" "$p" 2>/dev/null \
    || "$PB" -c "Add $key string $val" "$p"
}

plist_set_string_sudo() {
  local p="$1" key="$2" val="$3"
  sudo "$PB" -c "Set $key $val" "$p" 2>/dev/null \
    || sudo "$PB" -c "Add $key string $val" "$p"
}

plist_delete() {
  local p="$1" key="$2"
  "$PB" -c "Delete $key" "$p" 2>/dev/null || true
}

plist_delete_sudo() {
  local p="$1" key="$2"
  sudo "$PB" -c "Delete $key" "$p" 2>/dev/null || true
}

plist_get_string() {
  local p="$1" key="$2"
  "$PB" -c "Print $key" "$p" 2>/dev/null || true
}

config_value() {
  local key="$1"
  [ -f "$CONFIG_PATH" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  jq -er --arg key "$key" '.[$key] // empty' "$CONFIG_PATH" 2>/dev/null || true
}

config_csv() {
  local key="$1"
  [ -f "$CONFIG_PATH" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  jq -er --arg key "$key" '
    .[$key] // empty
    | if type == "array" then join(",")
      elif type == "string" then .
      else empty
      end
  ' "$CONFIG_PATH" 2>/dev/null || true
}

config_or_default() {
  local env_name="$1" key="$2" fallback="$3" val
  val="${!env_name:-}"
  if [ -n "$val" ]; then
    echo "$val"
    return
  fi
  val="$(config_value "$key")"
  if [ -n "$val" ]; then
    echo "$val"
    return
  fi
  echo "$fallback"
}

config_csv_or_default() {
  local env_name="$1" key="$2" fallback="$3" val
  val="${!env_name:-}"
  if [ -n "$val" ]; then
    echo "$val"
    return
  fi
  val="$(config_csv "$key")"
  if [ -n "$val" ]; then
    echo "$val"
    return
  fi
  echo "$fallback"
}

effective_upstream_proxy() {
  local val
  val="${HITMAN_UPSTREAM_PROXY:-${HITMAN_SOCKS:-}}"
  if [ -z "$val" ]; then
    val="$(config_value upstreamProxy)"
  fi
  echo "${val:-$DEFAULT_UPSTREAM_PROXY}"
}

effective_upstream_mode() {
  local val proxy
  val="${HITMAN_UPSTREAM_MODE:-}"
  if [ -z "$val" ]; then
    val="$(config_value upstreamMode)"
  fi
  if [ -n "$val" ]; then
    case "$val" in
      direct) echo "system" ;;
      *) echo "$val" ;;
    esac
    return
  fi
  proxy="$(effective_upstream_proxy)"
  if [ -n "$proxy" ]; then
    echo "proxy"
  else
    echo "$DEFAULT_UPSTREAM_MODE"
  fi
}

effective_listen_addr() { config_or_default HITMAN_LISTEN listen "127.0.0.1:$PORT"; }
effective_net_dns_addr() { config_or_default HITMAN_NETD_DNS netDNS "127.0.0.1:$DNS_PORT"; }
effective_mitm_addr() { config_or_default HITMAN_MITM_ADDR mitmAddr "127.0.0.1:$PORT"; }
effective_ca_dir() { config_or_default HITMAN_CA_DIR caDir "ca"; }
effective_domains() { config_csv_or_default HITMAN_DOMAINS domains "$DEFAULT_HITMAN_DOMAINS"; }
effective_domain_suffixes() { config_csv_or_default HITMAN_DOMAIN_SUFFIXES domainSuffixes "$DEFAULT_HITMAN_DOMAIN_SUFFIXES"; }
effective_processes() { config_csv_or_default HITMAN_PROCESSES processes "$DEFAULT_HITMAN_PROCESSES"; }
effective_resolver_domains() { config_csv_or_default HITMAN_RESOLVER_DOMAINS resolverDomains "$DEFAULT_HITMAN_RESOLVER_DOMAINS"; }
effective_dns_upstream() { config_or_default HITMAN_DNS_UPSTREAM upstreamDNS "$DEFAULT_DNS_UPSTREAM"; }

addr_port() { echo "${1##*:}"; }

ca_pem_path() {
  local ca_dir
  ca_dir="$(effective_ca_dir)"
  case "$ca_dir" in
    /*) echo "$ca_dir/hitman-ca.pem" ;;
    *) echo "$DIR/$ca_dir/hitman-ca.pem" ;;
  esac
}

cleanup_hitman_env() {
  local p="$1" key
  for key in \
    HITMAN_LISTEN HITMAN_UPSTREAM_MODE HITMAN_UPSTREAM_PROXY HITMAN_SOCKS \
    HITMAN_DNS_UPSTREAM HITMAN_ALLOW_HOSTS HITMAN_CA_DIR HITMAN_AUDIT_DIR \
    HITMAN_MARKER HITMAN_TRUNCATION_STEP HITMAN_MAX_TIER_N HITMAN_MAX_CONTINUE \
    HITMAN_DEBUG HITMAN_AUDIT_BODIES HITMAN_NETD_DNS HITMAN_MITM_ADDR \
    HITMAN_FAKEIP_CIDR HITMAN_TUN_ADDRESS HITMAN_TUN_NAME HITMAN_DOMAINS \
    HITMAN_DOMAIN_SUFFIXES HITMAN_PROCESSES HITMAN_PROCESS_PATHS \
    HITMAN_RESOLVER_DOMAINS; do
    plist_delete "$p" ":EnvironmentVariables:$key"
  done
}

write_upstream_config() {
  local upstream_mode="$1" upstream_proxy="$2" tmp
  need jq
  mkdir -p "$(dirname "$CONFIG_PATH")"
  tmp="$(mktemp)"
  if [ -f "$CONFIG_PATH" ]; then
    jq '.' "$CONFIG_PATH" >"$tmp"
  else
    printf '{}\n' >"$tmp"
  fi
  if [ "$upstream_mode" = "proxy" ]; then
    jq --arg mode "$upstream_mode" --arg proxy "$upstream_proxy" \
      '.upstreamMode = $mode | .upstreamProxy = $proxy' "$tmp" >"$tmp.next"
  else
    jq --arg mode "$upstream_mode" \
      '.upstreamMode = $mode | del(.upstreamProxy)' "$tmp" >"$tmp.next"
  fi
  mv "$tmp.next" "$CONFIG_PATH"
  rm -f "$tmp"
}

render_user_plist() {
  local p="$1"
  plist_set_string "$p" ":Label" "$LABEL"
  plist_set_string "$p" ":ProgramArguments:0" "$DIR/bin/hitman"
  plist_set_string "$p" ":StandardErrorPath" "$LOG_ERR"
  plist_set_string "$p" ":StandardOutPath" "$LOG_OUT"
  plist_set_string "$p" ":WorkingDirectory" "$DIR"
  plist_set_string "$p" ":EnvironmentVariables:HOME" "$HOME"
  plist_set_string "$p" ":EnvironmentVariables:PATH" "/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"
  cleanup_hitman_env "$p"
}

render_net_plist() {
  local p="$1"
  plist_set_string "$p" ":Label" "$NET_LABEL"
  plist_set_string "$p" ":ProgramArguments:0" "$DIR/bin/hitman"
  plist_set_string "$p" ":ProgramArguments:1" "netd"
  plist_set_string "$p" ":StandardErrorPath" "$NET_LOG_ERR"
  plist_set_string "$p" ":StandardOutPath" "$NET_LOG_OUT"
  plist_set_string "$p" ":WorkingDirectory" "$DIR"
  plist_set_string "$p" ":EnvironmentVariables:HOME" "$HOME"
  plist_set_string "$p" ":EnvironmentVariables:PATH" "/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"
  cleanup_hitman_env "$p"
}

cmd_build() {
  need go
  mkdir -p "$DIR/bin"
  ( cd "$DIR" && go build -tags with_gvisor -trimpath -o bin/hitman . )
  echo "built $DIR/bin/hitman (with_gvisor)"
}

start_user_service() {
  local err
  err="$(mktemp)"
  launchctl bootout "$GUI/$LABEL" 2>/dev/null || true
  for _ in 1 2 3 4 5; do
    if launchctl bootstrap "$GUI" "$PLIST_DST" 2>"$err"; then
      break
    fi
    if launchctl print "$GUI/$LABEL" >/dev/null 2>&1; then
      break
    fi
    sleep 0.2
  done
  if ! launchctl print "$GUI/$LABEL" >/dev/null 2>&1; then
    cat "$err" >&2
    rm -f "$err"
    return 1
  fi
  rm -f "$err"
  launchctl kickstart -k "$GUI/$LABEL"
}

start_net_service() {
  local err
  err="$(mktemp)"
  sudo launchctl bootout "system/$NET_LABEL" 2>/dev/null || true
  for _ in 1 2 3 4 5; do
    if sudo launchctl bootstrap system "$NET_PLIST_DST" 2>"$err"; then
      break
    fi
    if sudo launchctl print "system/$NET_LABEL" >/dev/null 2>&1; then
      break
    fi
    sleep 0.2
  done
  if ! sudo launchctl print "system/$NET_LABEL" >/dev/null 2>&1; then
    cat "$err" >&2
    rm -f "$err"
    return 1
  fi
  rm -f "$err"
  sudo launchctl kickstart -k "system/$NET_LABEL"
}

cmd_install_user() {
  mkdir -p "$DIR/logs" "$(dirname "$PLIST_DST")"
  cp "$PLIST_SRC" "$PLIST_DST"
  render_user_plist "$PLIST_DST"
  start_user_service
  echo "installed + started user service $LABEL"
}

cmd_install_net() {
  mkdir -p "$DIR/logs"
  local tmp
  tmp="$(mktemp)"
  cp "$NET_PLIST_SRC" "$tmp"
  render_net_plist "$tmp"
  sudo mkdir -p "$(dirname "$NET_PLIST_DST")"
  sudo cp "$tmp" "$NET_PLIST_DST"
  rm -f "$tmp"
  sudo chown root:wheel "$NET_PLIST_DST"
  sudo chmod 644 "$NET_PLIST_DST"
  start_net_service
  echo "installed + started root service $NET_LABEL"
}

cmd_install() {
  cmd_build
  cmd_install_user
  cmd_install_net
}

cleanup_resolvers() {
  local d path
  IFS=',' read -r -a domains <<<"$(effective_resolver_domains)"
  for d in "${domains[@]}"; do
    d="${d//[[:space:]]/}"
    [ -n "$d" ] || continue
    path="/etc/resolver/$d"
    if sudo test -f "$path" && sudo grep -qF "$RESOLVER_MARKER" "$path"; then
      sudo rm -f "$path"
    fi
  done
}

cmd_uninstall() {
  launchctl bootout "$GUI/$LABEL" 2>/dev/null || true
  sudo launchctl bootout "system/$NET_LABEL" 2>/dev/null || true
  rm -f "$PLIST_DST"
  sudo rm -f "$NET_PLIST_DST"
  cleanup_resolvers
  echo "uninstalled $LABEL and $NET_LABEL"
}

cmd_restart() {
  start_user_service
  if [ -f "$NET_PLIST_DST" ]; then
    start_net_service
    echo "restarted $LABEL and $NET_LABEL"
  else
    echo "restarted $LABEL (netd is not installed)"
  fi
}

cmd_on() {
  cmd_build
  cmd_install_user
  cmd_install_net
}

cmd_off() {
  sudo launchctl bootout "system/$NET_LABEL" 2>/dev/null || true
  cleanup_resolvers
  echo "capture disabled (netd stopped, hitman resolver files removed)"
}

cmd_upstream() {
  local mode="${1:-}" addr="${2:-}" upstream_mode val
  case "$mode" in
    socks|socks5) upstream_mode="proxy"; val="socks5://${addr:-$DEFAULT_SOCKS_UPSTREAM}" ;;
    http|mixed)   upstream_mode="proxy"; val="http://${addr:-$DEFAULT_HTTP_UPSTREAM}" ;;
    system|direct) upstream_mode="system"; val="" ;;
    *)            die "usage: hitman upstream <socks [addr] | http [addr] | system>" ;;
  esac
  write_upstream_config "$upstream_mode" "$val"
  echo "upstream mode set to: $upstream_mode"
  if [ "$upstream_mode" = "proxy" ]; then
    echo "upstream proxy set to: $val"
  else
    echo "upstream system DNS: $(effective_dns_upstream)"
  fi
  echo "config: $CONFIG_PATH"
  if [ -f "$PLIST_DST" ]; then
    cmd_install_user
  fi
  if [ -f "$NET_PLIST_DST" ]; then
    cmd_install_net
  fi
}

proxy_host_port() {
  local proxy="${1#socks5://}"
  proxy="${proxy#socks://}"
  proxy="${proxy#http://}"
  echo "$proxy"
}

tcp_port_open() {
  local port="$1"
  nc -z 127.0.0.1 "$port" >/dev/null 2>&1 \
    || lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1 \
    || sudo -n lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
}

dns_port_open() {
  local port="$1"
  tcp_port_open "$port" \
    || lsof -nP -iUDP:"$port" >/dev/null 2>&1 \
    || sudo -n lsof -nP -iUDP:"$port" >/dev/null 2>&1
}

print_launchd_state() {
  local label="$1" name="$2" out
  if out="$(launchctl print "$label" 2>/dev/null)"; then
    awk -v name="$name" '/state = /{print "  " name ": " $0; found=1; exit} END{if(!found) print "  " name ": loaded"}' <<<"$out"
  else
    echo "  $name: not loaded"
  fi
}

cmd_status() {
  local upstream_mode proxy hp host port dns_upstream listen_port dns_port
  echo "== launchd =="
  print_launchd_state "$GUI/$LABEL" "user"
  print_launchd_state "system/$NET_LABEL" "netd"

  listen_port="$(addr_port "$(effective_listen_addr)")"
  dns_port="$(addr_port "$(effective_net_dns_addr)")"
  echo "== listeners =="
  if tcp_port_open "$listen_port"; then echo "  mitm :$listen_port listening"; else echo "  mitm :$listen_port NOT listening"; fi
  if dns_port_open "$dns_port"; then echo "  dns  :$dns_port listening"; else echo "  dns  :$dns_port NOT listening"; fi

  echo "== upstream =="
  upstream_mode="$(effective_upstream_mode)"
  proxy="$(effective_upstream_proxy)"
  dns_upstream="$(effective_dns_upstream)"
  echo "  mode: $upstream_mode"
  if [ "$upstream_mode" = "system" ] || [ "$upstream_mode" = "direct" ]; then
    echo "  real-IP DNS: $dns_upstream"
  else
    if [ -z "$proxy" ]; then
      echo "  proxy: missing"
    else
      hp="$(proxy_host_port "$proxy")"
      host="${hp%:*}"
      port="${hp##*:}"
      echo "  proxy: $proxy"
      if nc -z "$host" "$port" >/dev/null 2>&1; then echo "  reachable"; else echo "  NOT reachable"; fi
    fi
  fi

  echo "== config =="
  echo "  path: $CONFIG_PATH"
  if [ -f "$CONFIG_PATH" ]; then echo "  source: file + defaults"; else echo "  source: defaults"; fi

  echo "== route =="
  if netstat -rn -f inet | awk '$1 ~ /^198[.]18[.]/ || $1 == "198.18/15" || $1 == "198.18.0.0/15" {found=1; print "  " $0} END{exit !found}'; then
    :
  else
    echo "  fake-IP route not found"
  fi

  echo "== resolvers =="
  local d path
  IFS=',' read -r -a domains <<<"$(effective_resolver_domains)"
  for d in "${domains[@]}"; do
    d="${d//[[:space:]]/}"
    [ -n "$d" ] || continue
    path="/etc/resolver/$d"
    if [ -f "$path" ] && grep -qF "$RESOLVER_MARKER" "$path"; then
      echo "  $d -> hitman"
    elif [ -f "$path" ]; then
      echo "  $d -> exists but not hitman-managed"
    else
      echo "  $d -> missing"
    fi
  done

  echo "== intercept targets =="
  echo "  domains: $(effective_domains)"
  echo "  domain_suffixes: $(effective_domain_suffixes)"
  echo "  processes: $(effective_processes)"

  echo "== CA trust =="
  if security find-certificate -c "hitman CA" /Library/Keychains/System.keychain >/dev/null 2>&1; then echo "  trusted"; else echo "  NOT trusted"; fi
}

cmd_logs() {
  tail -f "$LOG_ERR" "$LOG_OUT" "$NET_LOG_ERR" "$NET_LOG_OUT"
}

cmd_ca_trust() {
  local ca_pem
  ca_pem="$(ca_pem_path)"
  [ -f "$ca_pem" ] || die "CA not found at $ca_pem (start the service once first: ./hitman install)"
  echo "adding CA to System keychain (admin password required)..."
  sudo security add-trusted-cert -d -r trustRoot -k /Library/Keychains/System.keychain "$ca_pem"
  echo "CA trusted"
}

cmd_ca_untrust() {
  sudo security delete-certificate -c "hitman CA" /Library/Keychains/System.keychain 2>/dev/null || true
  echo "CA trust removed"
}

codex_token() {
  local token="${CODEX_TOKEN:-}"
  if [ -z "$token" ]; then
    need jq
    token="$(jq -r '.tokens.access_token // empty' "$HOME/.codex/auth.json" 2>/dev/null || true)"
  fi
  [ -n "$token" ] || die "no token: set CODEX_TOKEN or ensure ~/.codex/auth.json has .tokens.access_token"
  echo "$token"
}

cmd_smoke() {
  need go
  local ca_pem dns_port
  ca_pem="$(ca_pem_path)"
  dns_port="$(addr_port "$(effective_net_dns_addr)")"
  [ -f "$ca_pem" ] || die "CA not found at $ca_pem"
  if ! dns_port_open "$dns_port"; then
    die "netd DNS is not listening on :$dns_port (run ./hitman on)"
  fi
  local token tmp out
  token="$(codex_token)"
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' RETURN
  cat >"$tmp/smoke.go" <<'EOF'
package main

import (
	"crypto/tls"
	"crypto/x509"
	"fmt"
	"io"
	"net/http"
	"os"
	"time"
)

func main() {
	token := os.Getenv("CODEX_TOKEN")
	caPath := os.Getenv("HITMAN_CA_PEM")
	if token == "" || caPath == "" {
		fmt.Fprintln(os.Stderr, "missing CODEX_TOKEN or HITMAN_CA_PEM")
		os.Exit(2)
	}
	pool, err := x509.SystemCertPool()
	if err != nil || pool == nil {
		pool = x509.NewCertPool()
	}
	pem, err := os.ReadFile(caPath)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(2)
	}
	if !pool.AppendCertsFromPEM(pem) {
		fmt.Fprintln(os.Stderr, "failed to add hitman CA")
		os.Exit(2)
	}
	client := &http.Client{
		Timeout: 30 * time.Second,
		Transport: &http.Transport{
			TLSClientConfig: &tls.Config{RootCAs: pool},
		},
	}
	req, err := http.NewRequest(http.MethodGet, "https://chatgpt.com/backend-api/codex/models", nil)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(2)
	}
	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("User-Agent", "codex_cli_rs/0.142.5 (hitman smoke)")
	resp, err := client.Do(req)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	defer resp.Body.Close()
	n, _ := io.Copy(io.Discard, io.LimitReader(resp.Body, 1<<20))
	fmt.Printf("status=%d bytes=%d\n", resp.StatusCode, n)
}
EOF
  go build -trimpath -o "$tmp/codex" "$tmp/smoke.go"
  echo "sending /backend-api/codex/models through DNS/TUN/netd as process name 'codex'..."
  out="$(CODEX_TOKEN="$token" HITMAN_CA_PEM="$ca_pem" GODEBUG=netdns=cgo "$tmp/codex" 2>&1 || true)"
  if grep -q '^status=[1-5][0-9][0-9] bytes=' <<<"$out"; then
    echo "SMOKE PASS: DNS/TUN/netd -> hitman relayed HTTP response ($out)"
  else
    echo "SMOKE FAIL: Codex models request failed. Output:"; tail -n 5 <<<"$out"
    return 1
  fi
}

cmd_smoke_mitm() {
  need curl
  local ca_pem token out listen_addr listen_host listen_port
  ca_pem="$(ca_pem_path)"
  [ -f "$ca_pem" ] || die "CA not found at $ca_pem"
  listen_addr="$(effective_listen_addr)"
  listen_host="${listen_addr%:*}"
  listen_port="${listen_addr##*:}"
  token="$(codex_token)"
  echo "sending gpt-5.5 stream directly to MITM listener with curl --connect-to..."
  out="$(curl -sN --max-time 300 \
    --connect-to "chatgpt.com:443:$listen_host:$listen_port" --cacert "$ca_pem" \
    "https://chatgpt.com/backend-api/codex/responses" \
    -H "Authorization: Bearer $token" -H 'Content-Type: application/json' \
    -H 'User-Agent: codex_cli_rs/0.142.5 (hitman smoke-mitm)' \
    -d '{"model":"gpt-5.5","stream":true,"store":false,"input":[{"type":"message","role":"user","content":[{"type":"input_text","text":"Reply with the single word ok"}]}],"reasoning":{"effort":"low"}}' || true)"
  if grep -q 'proxy_rounds\|response.completed' <<<"$out"; then
    echo "SMOKE PASS: MITM relayed a terminal response.completed"
  else
    echo "SMOKE FAIL: no terminal event seen. Last lines:"; tail -n 5 <<<"$out"
    return 1
  fi
}

cmd_init() {
  cmd_install
  sleep 1
  cmd_ca_trust
  cmd_status
  cmd_smoke || echo "(smoke failed -- see status above and README troubleshooting)"
}

usage() {
  cat <<EOF
hitman - Human In The Middle · watch the Agent Network

Usage: ./hitman <command>

  init             build + install user/root services + trust CA + status + smoke
  build            go build -tags with_gvisor -> bin/hitman
  install          build + install/start user MITM and root netd
  uninstall        stop/remove both launchd services and hitman resolver files
  restart          kickstart both services
  on               build + start capture (same service path as install)
  off              stop root netd and remove hitman resolver files
  upstream         set upstream: socks [addr], http [addr], or system
  egress           alias for upstream
  ca-trust         add local CA to System keychain (sudo)
  ca-untrust       remove local CA from System keychain (sudo)
  status           show services, listeners, proxy, route, resolvers, CA state
  logs             tail MITM and netd logs
  smoke            live DNS/TUN/netd smoke using a temporary process named codex
  smoke-mitm       direct MITM-only smoke using curl --connect-to
EOF
}

case "${1:-}" in
  init) cmd_init ;;
  build) cmd_build ;;
  install) cmd_install ;;
  uninstall) cmd_uninstall ;;
  restart) cmd_restart ;;
  on) cmd_on ;;
  off) cmd_off ;;
  upstream|egress) cmd_upstream "${2:-}" "${3:-}" ;;
  ca-trust) cmd_ca_trust ;;
  ca-untrust) cmd_ca_untrust ;;
  status) cmd_status ;;
  logs) cmd_logs ;;
  smoke) cmd_smoke ;;
  smoke-mitm) cmd_smoke_mitm ;;
  ""|-h|--help|help) usage ;;
  *) usage; exit 1 ;;
esac
