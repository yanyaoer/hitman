#!/usr/bin/env bash
# hitman control script. Manages build, CA trust, the sing-box redirect rule,
# the launchd service, and smoke tests. See README.md.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LABEL="com.miclaw.hitman"
PORT=8471
SOCKS_PORT=2333
CA_PEM="$DIR/ca/hitman-ca.pem"
PLIST_SRC="$DIR/$LABEL.plist"
PLIST_DST="$HOME/Library/LaunchAgents/$LABEL.plist"
LOG_ERR="$DIR/logs/hitman.err.log"
LOG_OUT="$DIR/logs/hitman.out.log"
GUI="gui/$(id -u)"
PB=/usr/libexec/PlistBuddy

plist_set_string() {
  local p="$1" key="$2" val="$3"
  "$PB" -c "Set $key $val" "$p" 2>/dev/null \
    || "$PB" -c "Add $key string $val" "$p"
}

render_launchd_plist() {
  local p="$1"
  plist_set_string "$p" ":Label" "$LABEL"
  plist_set_string "$p" ":ProgramArguments:0" "$DIR/bin/hitman"
  plist_set_string "$p" ":StandardErrorPath" "$LOG_ERR"
  plist_set_string "$p" ":StandardOutPath" "$LOG_OUT"
  plist_set_string "$p" ":WorkingDirectory" "$DIR"
  plist_set_string "$p" ":EnvironmentVariables:HITMAN_SOCKS" "${HITMAN_SOCKS:-direct}"
}

# sing-box integration — supports two deployment modes:
#   sfm : SFM.app (NetworkExtension); config lives in the group container, reload = reconnect the profile.
#   cli : `sing-box run -c <cfg>` (manual or under launchd); reload = restart that process/service.
# Mode + paths are auto-detected but fully overridable by HITMAN_SB_* env.
SB_BIN="${HITMAN_SB_BIN:-/opt/homebrew/bin/sing-box}"
SB_MODE="${HITMAN_SB_MODE:-auto}"                      # sfm | cli | auto
TUN_INBOUND="${HITMAN_TUN_INBOUND:-tun-in}"            # inbound tag the redirect rule scopes to
DIRECT_OUTBOUND="${HITMAN_DIRECT_OUTBOUND:-DIRECT}"    # a direct (non-proxy) outbound tag in the sing-box config
SB_CONFIG_ENV="${HITMAN_SB_CONFIG:-}"
SB_RELOAD_ENV="${HITMAN_SB_RELOAD:-}"
SB_LAUNCHD_ENV="${HITMAN_SB_LAUNCHD:-}"
SFM_CFG="$HOME/Library/Group Containers/287TTNZF8L.io.nekohasekai.sfavt/configs/config_2.json"
SB_CFG=""                                             # resolved lazily by sb_resolve

# The redirect rule. outbound=DIRECT is REQUIRED: after override_address/port rewrite
# the destination to 127.0.0.1:PORT, sing-box must dial it locally — without an
# explicit direct outbound it falls to route.final (a proxy node), which then tries
# to reach 127.0.0.1:PORT on the remote server and the connection is reset.
# Idempotency key is override_port == PORT.
REDIRECT_RULE='{"action":"route","inbound":["'"$TUN_INBOUND"'"],"process_name":["codex"],"domain":["chatgpt.com"],"outbound":"'"$DIRECT_OUTBOUND"'","override_address":"127.0.0.1","override_port":'"$PORT"'}'

die() { echo "hitman: $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing required tool: $1"; }

cmd_build() {
  need go
  ( cd "$DIR" && go build -trimpath -o bin/hitman . )
  echo "built $DIR/bin/hitman"
}

cmd_install() {
  mkdir -p "$DIR/logs" "$(dirname "$PLIST_DST")"
  cp "$PLIST_SRC" "$PLIST_DST"
  render_launchd_plist "$PLIST_DST"
  launchctl bootstrap "$GUI" "$PLIST_DST" 2>/dev/null || true
  launchctl kickstart -k "$GUI/$LABEL"
  echo "installed + started launchd service $LABEL"
}

cmd_uninstall() {
  launchctl bootout "$GUI/$LABEL" 2>/dev/null || true
  rm -f "$PLIST_DST"
  echo "uninstalled launchd service $LABEL"
}

cmd_restart() { launchctl kickstart -k "$GUI/$LABEL"; echo "restarted $LABEL"; }

# egress <socks [addr] | direct>: set how hitman reaches the upstream.
#   socks : dial via sing-box socks-in (default 127.0.0.1:2333) — needs the socks port reachable.
#   direct: dial chatgpt.com straight and let the sing-box TUN capture it — use when
#           strict_route blocks the socks inbound. Loop-safe only with process-scoped redirect.
cmd_egress() {
  local mode="${1:-}" addr="${2:-127.0.0.1:2333}" val
  case "$mode" in
    direct) val="direct" ;;
    socks)  val="$addr" ;;
    *) die "usage: hitman egress <socks [addr] | direct>" ;;
  esac
  for p in "$PLIST_SRC" "$PLIST_DST"; do
    [ -f "$p" ] || continue
    plist_set_string "$p" ":EnvironmentVariables:HITMAN_SOCKS" "$val"
  done
  echo "egress set to: $val"
  if [ -f "$PLIST_DST" ]; then
    launchctl bootout "$GUI/$LABEL" 2>/dev/null || true
    launchctl bootstrap "$GUI" "$PLIST_DST" 2>/dev/null || true
    launchctl kickstart -k "$GUI/$LABEL"
    echo "restarted $LABEL"
  fi
}

cmd_ca_trust() {
  [ -f "$CA_PEM" ] || die "CA not found at $CA_PEM (run the service once first: ./hitman install)"
  echo "adding CA to System keychain (admin password required)..."
  sudo security add-trusted-cert -d -r trustRoot -k /Library/Keychains/System.keychain "$CA_PEM"
  echo "CA trusted"
}

cmd_ca_untrust() {
  sudo security delete-certificate -c "hitman CA" /Library/Keychains/System.keychain 2>/dev/null || true
  echo "CA trust removed"
}

# sb_cli_config sets SB_CFG to the first existing sing-box CLI config; returns 1 if none.
sb_cli_config() {
  local c
  for c in "$SB_CONFIG_ENV" "$HOME/.config/sing-box/config.json" \
           /opt/homebrew/etc/sing-box/config.json /usr/local/etc/sing-box/config.json /etc/sing-box/config.json; do
    if [ -n "$c" ] && [ -f "$c" ]; then SB_CFG="$c"; return 0; fi
  done
  return 1
}

# sb_resolve sets SB_CFG + SB_MODE from env / auto-detection; returns 1 if no config found.
sb_resolve() {
  if [ -n "$SB_CONFIG_ENV" ]; then
    SB_CFG="$SB_CONFIG_ENV"
    [ -f "$SB_CFG" ] || return 1
    case "$SB_MODE" in sfm|cli) : ;; *) case "$SB_CFG" in *sfavt*) SB_MODE=sfm ;; *) SB_MODE=cli ;; esac ;; esac
    return 0
  fi
  case "$SB_MODE" in
    sfm) SB_CFG="$SFM_CFG"; [ -f "$SB_CFG" ] || return 1; return 0 ;;
    cli) sb_cli_config; return $? ;;
    *)   if [ -f "$SFM_CFG" ]; then SB_MODE=sfm; SB_CFG="$SFM_CFG"; return 0; fi
         SB_MODE=cli; sb_cli_config; return $? ;;
  esac
}

# sb_reload applies the just-written config to the running sing-box (mode-specific).
sb_reload() {
  if [ -n "$SB_RELOAD_ENV" ]; then
    echo "reloading sing-box via HITMAN_SB_RELOAD..."
    eval "$SB_RELOAD_ENV"
    return 0
  fi
  case "$SB_MODE" in
    sfm)
      echo "NOTE: reload SFM — reconnect the active profile in the SFM app for the change to apply." ;;
    cli)
      if [ -n "$SB_LAUNCHD_ENV" ]; then
        launchctl kickstart -k "$GUI/$SB_LAUNCHD_ENV" 2>/dev/null \
          || sudo launchctl kickstart -k "system/$SB_LAUNCHD_ENV" 2>/dev/null \
          || echo "WARN: could not kickstart launchd service $SB_LAUNCHD_ENV"
        echo "restarted sing-box launchd service $SB_LAUNCHD_ENV"
      elif pgrep -x sing-box >/dev/null 2>&1; then
        echo "NOTE: restart your sing-box CLI to load the new config (it does not hot-reload the config file):"
        echo "      sudo $SB_BIN run -c \"$SB_CFG\"   (or set HITMAN_SB_RELOAD / HITMAN_SB_LAUNCHD)"
      else
        echo "NOTE: sing-box does not appear to be running; start it with the updated config."
      fi ;;
  esac
}

# _sb_apply <jq-program> [jq-args...]: resolve config, back up, run the jq transform,
# validate with `sing-box check`, atomically swap it in, then reload (mode-aware).
_sb_apply() {
  local prog="$1"; shift
  need jq
  [ -x "$SB_BIN" ] || die "sing-box not found at $SB_BIN (set HITMAN_SB_BIN)"
  sb_resolve || die "no sing-box config found; set HITMAN_SB_CONFIG=/path/to/config.json"
  local ts tmp
  ts="$(date +%Y%m%dT%H%M%S)"
  cp "$SB_CFG" "$SB_CFG.bak-hitman-$ts"
  tmp="$(mktemp)"
  jq "$@" "$prog" "$SB_CFG" >"$tmp" || { rm -f "$tmp"; die "jq transform failed"; }
  "$SB_BIN" check -c "$tmp" || { rm -f "$tmp"; die "sing-box check failed; config unchanged (backup: $SB_CFG.bak-hitman-$ts)"; }
  mv "$tmp" "$SB_CFG"
  echo "[$SB_MODE] sing-box config updated: $SB_CFG (backup: $SB_CFG.bak-hitman-$ts)"
  sb_reload
}

cmd_singbox_patch() {
  # Remove any prior hitman rule (match on override_port) then insert the current
  # one right after the leading sniff/hijack-dns rules, so re-running `on` upgrades
  # the rule in place and it takes priority over real routing rules (first-match wins).
  _sb_apply '
    def leadlen($rules):
      reduce $rules[] as $x ({n:0, stop:false};
        if .stop then .
        elif ($x.action == "sniff" or $x.action == "hijack-dns") then {n:(.n+1), stop:false}
        else {n:.n, stop:true} end).n;
    (.route.rules | map(select(.override_port? != '"$PORT"'))) as $c
    | leadlen($c) as $at
    | .route.rules = ($c[0:$at] + [$r] + $c[$at:])
  ' --argjson r "$REDIRECT_RULE"
}

cmd_singbox_unpatch() {
  _sb_apply '.route.rules |= map(select(.override_port? != '"$PORT"'))'
}

cmd_on()  { cmd_singbox_patch; }
cmd_off() { cmd_singbox_unpatch; }

cmd_status() {
  echo "== launchd =="
  launchctl print "$GUI/$LABEL" 2>/dev/null | awk '/state = /{print; exit}' || echo "  not loaded"
  echo "== listener :$PORT =="
  if lsof -nP -iTCP:"$PORT" -sTCP:LISTEN >/dev/null 2>&1; then echo "  listening"; else echo "  NOT listening"; fi
  echo "== egress =="
  local eg="127.0.0.1:2333"
  [ -f "$PLIST_DST" ] && eg="$("$PB" -c 'Print :EnvironmentVariables:HITMAN_SOCKS' "$PLIST_DST" 2>/dev/null || echo '127.0.0.1:2333')"
  case "$eg" in ""|direct|none|off|-) echo "  direct (via TUN)";; *) echo "  socks $eg";; esac
  echo "== sing-box socks :$SOCKS_PORT =="
  if nc -z 127.0.0.1 "$SOCKS_PORT" >/dev/null 2>&1; then echo "  reachable"; else echo "  NOT reachable (ok if egress=direct)"; fi
  echo "== sing-box config =="
  if sb_resolve; then echo "  mode=$SB_MODE  config=$SB_CFG"; else echo "  NOT found (set HITMAN_SB_CONFIG)"; fi
  echo "== redirect rule =="
  if command -v jq >/dev/null 2>&1 && [ -n "$SB_CFG" ] && [ -f "$SB_CFG" ] && jq -e '.route.rules | any(.override_port? == '"$PORT"')' "$SB_CFG" >/dev/null 2>&1; then
    echo "  present (hitman ON)"; else echo "  absent (hitman OFF / direct)"; fi
  echo "== CA trust =="
  if security find-certificate -c "hitman CA" /Library/Keychains/System.keychain >/dev/null 2>&1; then echo "  trusted"; else echo "  NOT trusted"; fi
}

cmd_logs() { tail -f "$LOG_ERR" "$LOG_OUT"; }

cmd_smoke() {
  need curl; need jq
  [ -f "$CA_PEM" ] || die "CA not found at $CA_PEM"
  local token="${CODEX_TOKEN:-}"
  if [ -z "$token" ]; then token="$(jq -r '.tokens.access_token // empty' "$HOME/.codex/auth.json" 2>/dev/null || true)"; fi
  [ -n "$token" ] || die "no token: set CODEX_TOKEN or ensure ~/.codex/auth.json has .tokens.access_token"
  if ! nc -z 127.0.0.1 "$SOCKS_PORT" >/dev/null 2>&1; then
    echo "WARN: socks $SOCKS_PORT not reachable. If egress=socks this smoke will fail;" >&2
    echo "      if strict_route blocks the socks inbound, switch: ./hitman egress direct" >&2
  fi
  echo "sending gpt-5.5 stream through hitman (chatgpt.com -> 127.0.0.1:$PORT)..."
  # --connect-to keeps the URL host as chatgpt.com:443 (correct upstream port + Host header)
  # while dialing local hitman; --resolve would leak :$PORT into Host and upstream.
  local out
  out="$(curl -sN --max-time 300 \
    --connect-to "chatgpt.com:443:127.0.0.1:$PORT" --cacert "$CA_PEM" \
    "https://chatgpt.com/backend-api/codex/responses" \
    -H "Authorization: Bearer $token" -H 'Content-Type: application/json' \
    -H 'User-Agent: codex_cli_rs/0.142.5 (smoke)' \
    -d '{"model":"gpt-5.5","stream":true,"store":false,"input":[{"type":"message","role":"user","content":[{"type":"input_text","text":"Reply with the single word ok"}]}],"reasoning":{"effort":"low"}}' || true)"
  # With folding on you get metadata.proxy_rounds; with the default (max_continue=0)
  # the fold path still stamps response.completed — treat either terminal as pass.
  if grep -q 'proxy_rounds\|response.completed' <<<"$out"; then
    echo "SMOKE PASS: hitman relayed a terminal response.completed (proxy_rounds present iff folding enabled)"
  else
    echo "SMOKE FAIL: no terminal event seen. Last lines:"; tail -n 5 <<<"$out"
    return 1
  fi
}

cmd_init() {
  cmd_build
  cmd_install
  sleep 1
  cmd_ca_trust
  cmd_singbox_patch
  cmd_status
  cmd_smoke || echo "(smoke failed — see status above and README troubleshooting)"
}

usage() {
  cat <<EOF
hitman — Human In The Middle · watch the Agent Network

Usage: ./hitman <command>

  init             build + install + trust CA + patch sing-box + status + smoke (one-time)
  build            go build -> bin/hitman
  install          copy plist + launchd bootstrap + start (auto-creates CA on first run)
  uninstall        stop + remove launchd service
  restart          kickstart the service
  egress <mode>    set upstream egress: 'socks [addr]' (default 2333) or 'direct' (via TUN)
  ca-trust         add local CA to System keychain (sudo)
  ca-untrust       remove local CA from System keychain (sudo)
  on               add sing-box redirect rule (codex -> hitman)
  off              remove sing-box redirect rule (codex -> chatgpt.com direct)
  singbox-patch    same as 'on' (idempotent, sing-box check + backup)
  singbox-unpatch  same as 'off'
  status           show launchd / listener / socks / rule / CA state
  logs             tail service logs
  smoke            send a gpt-5.5 stream through hitman and check for a terminal response
EOF
}

case "${1:-}" in
  init) cmd_init ;;
  build) cmd_build ;;
  install) cmd_install ;;
  uninstall) cmd_uninstall ;;
  restart) cmd_restart ;;
  egress) cmd_egress "${2:-}" "${3:-}" ;;
  ca-trust) cmd_ca_trust ;;
  ca-untrust) cmd_ca_untrust ;;
  on) cmd_on ;;
  off) cmd_off ;;
  singbox-patch) cmd_singbox_patch ;;
  singbox-unpatch) cmd_singbox_unpatch ;;
  status) cmd_status ;;
  logs) cmd_logs ;;
  smoke) cmd_smoke ;;
  ""|-h|--help|help) usage ;;
  *) usage; exit 1 ;;
esac
